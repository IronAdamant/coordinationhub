{
  "agents": [
    {
      "id": "architect",
      "role": "plan and design",
      "model": "claude-opus-4",
      "responsibilities": [
        "design architecture",
        "plan implementation",
        "coordinate agents",
        "decompose tasks",
        "review code"
      ]
    },
    {
      "id": "builder",
      "role": "implement features",
      "model": "minimax-m2.7",
      "responsibilities": [
        "write code",
        "implement features",
        "modify files",
        "run tests"
      ]
    },
    {
      "id": "finisher",
      "role": "polish, fix, and harden",
      "model": "claude-opus-4",
      "responsibilities": [
        "review code",
        "fix bugs",
        "write tests",
        "edit documentation",
        "modify files"
      ]
    },
    {
      "id": "explorer",
      "role": "research and investigate",
      "model": "claude-haiku-4",
      "responsibilities": [
        "read code",
        "search codebase",
        "explore architecture",
        "research patterns"
      ]
    }
  ],
  "handoffs": [
    {
      "from": "architect",
      "to": "builder",
      "condition": "implementation plan approved"
    },
    {
      "from": "builder",
      "to": "finisher",
      "condition": "feature implementation complete"
    },
    {
      "from": "finisher",
      "to": "architect",
      "condition": "review reveals design issues"
    },
    {
      "from": "finisher",
      "to": "builder",
      "condition": "review feedback requires changes"
    },
    {
      "from": "architect",
      "to": "explorer",
      "condition": "investigation needed before planning"
    },
    {
      "from": "explorer",
      "to": "architect",
      "condition": "research complete"
    }
  ],
  "escalation": {
    "max_retries": 3,
    "fallback": "human_review"
  },
  "assessment": {
    "metrics": [
      "role_stability",
      "handoff_latency",
      "outcome_verifiability",
      "protocol_adherence",
      "spawn_propagation"
    ]
  }
}
